{
  "manifest_version": 2,
  "name": "TradeTool POE2 TP Bridge",
  "version": "0.1.0",
  "description": "Lets TradeTool ask logged-in Firefox to send POE2 trade hideout TP requests.",
  "browser_specific_settings": {
    "gecko": {
      "id": "tradetool-poe2-bridge@tradeproject.local",
      "strict_min_version": "109.0"
    }
  },
  "permissions": [
    "storage",
    "tabs",
    "https://www.pathofexile.com/*",
    "http://127.0.0.1/*"
  ],
  "background": {
    "scripts": ["background.js"]
  },
  "content_scripts": [
    {
      "matches": ["https://www.pathofexile.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "browser_action": {
    "default_title": "TradeTool POE2 TP Bridge"
  },
  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  }
}
