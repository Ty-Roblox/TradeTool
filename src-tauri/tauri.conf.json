{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "TradeProject",
  "version": "0.1.0",
  "identifier": "com.ty.tradeproject",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../build"
  },
  "app": {
    "windows": [
      {
        "title": "TradeProject",
        "width": 800,
        "height": 600
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEEzMDhCMUVERENFMUNENEYKUldSUHplSGM3YkVJbys3cVhsUllhU1dha0VvSGpoeWdCclZrZXBBejRBTS9QMW54RHQwWkVZVE4K",
      "endpoints": [
        "https://github.com/Ty-Roblox/TradeTool/releases/latest/download/latest.json"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
